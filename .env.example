# ============================================================
# SituationRoom — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# --- Database ---
POSTGRES_PASSWORD=password

# --- AIS (Maritime Traffic) ---
# Free API key from https://aisstream.io/
AISSTREAM_API_KEY=your_aisstream_key_here

# --- ADS-B (Air Traffic) ---
# OpenSky now uses OAuth2 client credentials. Register at https://opensky-network.org/
# and create an API client under "My OpenSky" → "API credentials".
# Both values are required for authenticated access; leave blank for anonymous
# (anonymous is heavily rate-limited: 1 req/10 s, no auth = fewer aircraft).
OPENSKY_CLIENT_ID=your_opensky_client_id
OPENSKY_CLIENT_SECRET=your_opensky_client_secret

# --- API Gateway ---
API_PORT=8080
CORS_ORIGINS=http://localhost,http://localhost:5173

# Admin key for event mutation endpoints (POST/DELETE /api/events).
# REQUIRED — the API will refuse to start if this is not set.
# Use any long random string, e.g.: openssl rand -hex 32
ADMIN_KEY=change_me_before_deploying

# ADS-B geographic bounding box (lamin, lomin, lamax, lomax)
# Default: North Atlantic + Europe + Middle East (~3,500 aircraft vs ~10,000 global)
ADSB_BBOX=20,-80,75,60

# AIS geographic bounding box — same format as ADSB_BBOX
# Reduce to a smaller region to limit ship volume (global = tens of thousands)
AIS_BBOX=20,-80,75,60

# --- Satellites ---
# CelesTrak constellation group to fetch hourly.
# Options: starlink, iridium-next, active, stations, gps-ops, galileo, oneweb
# "starlink" (~6,000 satellites) is the most visually dense.
SATELLITE_CONSTELLATION=starlink

# --- Frontend (dev only — not used in production Docker build) ---
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
